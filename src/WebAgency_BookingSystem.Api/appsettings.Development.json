{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=bookingsystem;Username=postgres;Password=postgres"
  },
  "Database": {
    "AutoMigrate": true
  },
  "Jwt": {
    "Secret": "dev-only-jwt-secret-change-me-min-32-characters-long",
    "ExpiryHours": 8,
    "Issuer": "WebAgency_BookingSystem",
    "Audience": "WebAgency_BookingSystem.Admin"
  },
  "RateLimiting": {
    "PermitPerMinute": 100,
    "IpPermitPerMinute": 300
  },
  "Email": {
    "Provider": "Mailpit",
    "SenderEmail": "noreply@bookingsystem.local",
    "SenderName": "BookingSystem (dev)",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025
    }
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
