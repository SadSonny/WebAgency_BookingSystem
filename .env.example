# [INTENT]: Template delle variabili d'ambiente richieste dall'API. Copia in `.env` (gitignored)
# per lo sviluppo locale, oppure configura queste chiavi nell'ambiente Railway per la produzione.
# I nomi flat (DATABASE_URL, JWT_SECRET, ...) hanno priorità sulle sezioni di appsettings.json a runtime.
# NON committare mai il file `.env` con valori reali.

# ── Database ────────────────────────────────────────────────────────────────
# Connection string Npgsql. In locale corrisponde al servizio postgres di docker-compose.
# Su Railway è fornita automaticamente dal plugin PostgreSQL.
DATABASE_URL=Host=localhost;Port=5432;Database=bookingsystem;Username=postgres;Password=postgres

# ── JWT admin ───────────────────────────────────────────────────────────────
# Segreto per la firma dei token JWT admin. Minimo 32 caratteri. Generane uno random in produzione.
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars
# Validità del token in ore (default applicativo: 8).
JWT_EXPIRY_HOURS=8

# ── Rate limiting ───────────────────────────────────────────────────────────
# Richieste massime al minuto per API key (default applicativo: 100).
RATE_LIMIT_PER_MINUTE=100
# Richieste massime al minuto per IP (limite globale a monte dell'auth, anti brute-force; default: 300).
RATE_LIMIT_IP_PER_MINUTE=300

# ── Email (Brevo) — V2 ──────────────────────────────────────────────────────
# In V1 l'IEmailService è uno stub no-op: queste variabili non sono usate finché non si integra Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@dominio.com
BREVO_SENDER_NAME=BookingSystem
